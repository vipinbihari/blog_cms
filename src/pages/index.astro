---
import { getCollection } from 'astro:content';
import { compareDesc } from 'date-fns';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import '../styles/hero-animation.css';

// Initialize with empty arrays to handle case where collection doesn't exist yet
let sortedPosts = [];
let featuredPosts = [];
let categories = [];

try {
  // Get all blog posts and sort by date (newest first)
  const allPosts = await getCollection('posts');
  
  if (allPosts && allPosts.length > 0) {
    sortedPosts = allPosts.sort((a, b) => 
      compareDesc(a.data.date, b.data.date)
    );
    
    // Featured posts (most recent 3)
    featuredPosts = sortedPosts.slice(0, 3);
    
    // Categories
    categories = [...new Set(allPosts.map(post => post.data.category))];
  }
} catch (error) {
  console.error('Error fetching posts for homepage:', error);
}
---

<BaseLayout
  title="StockSage - Insightful Stock Market Analysis and Education"
  description="Expert analysis and practical lessons on Indian and global stock markets, breaking news, and technical & fundamental analysis."
  image="/images/og-image.jpg"
>
  <!-- Hero section with stock market animation -->
  <section class="hero-section bg-primary-50 dark:bg-gray-800 py-16 mb-12 relative">
    <!-- Animated chart lines -->
    <div class="chart-line"></div>
    <div class="chart-line"></div>
    <div class="chart-line"></div>
    <div class="chart-line"></div>
    
    <!-- Stock ticker animations -->
    <div class="stock-ticker">NIFTY 22,456 <span class="text-green-500">▲ 1.2%</span> SENSEX 73,890 <span class="text-green-500">▲ 0.9%</span> HDFC 1,678 <span class="text-red-500">▼ 0.3%</span> RELIANCE 2,890 <span class="text-green-500">▲ 1.5%</span> TCS 3,456 <span class="text-green-500">▲ 0.7%</span> INFY 1,567 <span class="text-red-500">▼ 0.2%</span></div>
    <div class="stock-ticker">BAJAJ 4,567 <span class="text-red-500">▼ 0.5%</span> ICICI 945 <span class="text-green-500">▲ 1.1%</span> ADANI 2,345 <span class="text-green-500">▲ 2.3%</span> WIPRO 456 <span class="text-red-500">▼ 0.8%</span> TATA 789 <span class="text-green-500">▲ 0.6%</span> SBI 678 <span class="text-green-500">▲ 1.3%</span></div>
    <div class="stock-ticker">BHARTI 890 <span class="text-red-500">▼ 0.4%</span> MARUTI 10,234 <span class="text-green-500">▲ 0.8%</span> AXIS 978 <span class="text-green-500">▲ 1.0%</span> NTPC 234 <span class="text-red-500">▼ 0.2%</span> LT 2,456 <span class="text-green-500">▲ 1.7%</span> ONGC 189 <span class="text-red-500">▼ 0.3%</span></div>
    <div class="stock-ticker">SUNPHARMA 1,123 <span class="text-green-500">▲ 0.9%</span> HCLTECH 1,345 <span class="text-red-500">▼ 0.1%</span> ASIANPAINT 3,456 <span class="text-green-500">▲ 0.5%</span> TITAN 2,789 <span class="text-green-500">▲ 1.2%</span> ULTRACEMCO 8,567 <span class="text-red-500">▼ 0.7%</span></div>
    
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          Stock Market Insights & Education
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-3xl mx-auto">
          Practical analysis, breaking news, and easy-to-understand lessons on technical and fundamental trading strategies.
        </p>
        <div class="flex justify-center space-x-4">
          <a 
            href="#featured" 
            class="bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-md font-medium shadow-sm"
          >
            Read Latest Articles
          </a>
          <a 
            href="/categories/technical-analysis" 
            class="bg-white dark:bg-gray-700 text-primary-600 dark:text-primary-400 hover:bg-gray-50 dark:hover:bg-gray-600 px-6 py-3 rounded-md font-medium shadow-sm border border-gray-300 dark:border-gray-600"
          >
            Technical Analysis
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Featured posts section -->
  <section id="featured" class="py-12 mb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8 text-center md:text-left">Featured Articles</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        {featuredPosts.map((post) => {
          const placeholderImageUrl = `https://placehold.co/400x200?text=${encodeURIComponent(post.data.title.replace(/\s+/g, '+'))}`;
          const displayImage = post.data.heroImage || placeholderImageUrl;
          return (
          <article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 transform hover:translate-y-[-5px] overflow-hidden">
            {/* Always render an image, using placeholder if heroImage is missing */}
            <div class="overflow-hidden">
              <a href={`/posts/${post.slug}/`} class="no-underline block">
                <ResponsiveImage
                  src={displayImage}
                  alt={post.data.title}
                  class="w-full h-52 object-cover transition-transform duration-300 hover:scale-105"
                  width={320}
                  height={180}
                  sizes="320px"
                  loading="lazy"
                />
              </a>
            </div>
            
            <div class="p-6">
              <a 
                href={`/categories/${post.data.category.toLowerCase().replace(/\s+/g, '-')}/`}
                class="text-xs font-medium inline-block bg-primary-100 dark:bg-primary-900/50 text-primary-800 dark:text-primary-100 px-3 py-1 rounded-full mb-4 no-underline hover:bg-primary-200 dark:hover:bg-primary-900 transition-colors"
              >
                {post.data.category}
              </a>
              
              <h3 class="text-xl font-bold mb-3">
                <a 
                  href={`/posts/${post.slug}/`}
                  class="text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 transition-colors no-underline"
                >
                  {post.data.title}
                </a>
              </h3>
              
              <p class="text-gray-600 dark:text-gray-300 mb-4 line-clamp-2">
                {post.data.excerpt}
              </p>
              
              <div class="flex items-center justify-between mt-auto pt-3 text-sm border-t border-gray-100 dark:border-gray-700">
                <span class="font-medium text-gray-700 dark:text-gray-300">By {post.data.author}</span>
                <span class="text-primary-600 dark:text-primary-400">
                  <FormattedDate date={post.data.date} />
                </span>
              </div>
            </div>
          </article>
        ); // Added semicolon for clarity, ensured correct closing
        })}
      </div>
      
      <div class="mt-10 text-center">
        <a 
          href="/posts/page/1" 
          class="inline-block text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-medium"
        >
          View All Articles →
        </a>
      </div>
    </div>
  </section>
  
  <!-- Categories section -->
  <section class="py-12 bg-gray-50 dark:bg-gray-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Categories</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map((category) => (
          <a 
            href={`/categories/${category.toLowerCase().replace(/\s+/g, '-')}/`}
            class="bg-white dark:bg-gray-700 p-6 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col justify-between h-full"
          >
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">{category}</h3>
            <span class="text-primary-600 dark:text-primary-400 font-medium mt-4">View Articles →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
