---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getRelatedPosts } from '../../lib/content/queries';
import ResponsiveImage from '../../components/ResponsiveImage.astro';

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  
  return await Promise.all(allPosts.map(async entry => {
    // Get related posts for this entry
    const relatedPosts = await getRelatedPosts(entry, 3);
    
    return {
      params: { slug: entry.slug },
      props: { entry, relatedPosts },
    };
  }));
}

const { entry, relatedPosts } = Astro.props;
const { Content } = await entry.render();
---

<PostLayout post={entry} content={Content} relatedPosts={relatedPosts}>
  <Content components={{ img: ResponsiveImage }} />
</PostLayout>
