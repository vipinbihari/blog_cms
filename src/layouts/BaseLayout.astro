---
import { SEO } from 'astro-seo';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: URL;
}

const {
  title,
  description = 'Expert analysis and practical lessons on Indian and global stock markets.',
  image = 'https://placehold.co/1200x630?text=StockSage+Blog',
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
} = Astro.props;


---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Theme initialization script (must be in head to avoid FOUC) -->
    <script is:inline>
      // Check for saved theme preference or use the system preference
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      
      const theme = getThemePreference();
      
      // Apply the theme class to the document
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
    
    <SEO
      title={`${title || "StockSage"} | StockSage`}
      description={description || "Expert analysis and practical lessons on Indian and global stock markets."}
      canonical={canonicalURL ? canonicalURL.toString() : "https://stocksage.com"}
      openGraph={{
        basic: {
          title: title || "StockSage",
          type: "website",
          image: image || "https://placehold.co/1200x630?text=StockSage+Blog"
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: title || "StockSage",
        description: description || "Expert analysis and practical lessons on Indian and global stock markets.",
        image: image || "https://placehold.co/1200x630?text=StockSage+Blog"
      }}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white dark:bg-gray-900">
    <Header />
    
    <main class="flex-1">
      <slot />
    </main>
    
    <Footer />
    
    <script>
      // Check for dark mode preference
      if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </body>
</html>
