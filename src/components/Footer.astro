---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="md:flex md:justify-between">
      <!-- Site info and description -->  
      <div class="mb-8 md:mb-0 md:w-1/3">
        <a href="/" class="flex items-center mb-4">
          <span class="text-xl font-bold text-primary-600 dark:text-primary-400">StockSage</span>
        </a>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          Insightful analysis and practical lessons on Indian and global stock markets.
        </p>
        <div class="flex space-x-4">
          <!-- Social media icons -->  
          <a href="#" class="text-gray-500 hover:text-primary-600 dark:hover:text-primary-400">
            <span class="sr-only">Twitter</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
            </svg>
          </a>
          <a href="#" class="text-gray-500 hover:text-primary-600 dark:hover:text-primary-400">
            <span class="sr-only">LinkedIn</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation Links -->  
      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:w-2/3">
        <div>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-4">Categories</h3>
          <ul class="space-y-3">
            <li>
              <a href="/categories/technical-analysis" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400">
                Technical Analysis
              </a>
            </li>
            <li>
              <a href="/categories/fundamental-analysis" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400">
                Fundamental Analysis
              </a>
            </li>
            <li>
              <a href="/categories/market-news" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400">
                Market News
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-4">Resources</h3>
          <ul class="space-y-3">
            <li>
              <a href="/about" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400">
                About Us
              </a>
            </li>
            <li>
              <a href="/contact" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400">
                Contact
              </a>
            </li>
            <li>
              <a href="/sitemap.xml" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400">
                Sitemap
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-4">Subscribe</h3>
          <p class="text-gray-600 dark:text-gray-400 mb-4">Get the latest updates directly to your inbox.</p>
          <form class="flex">
            <input
              type="email"
              required
              placeholder="Your email"
              class="min-w-0 flex-1 px-3 py-2 rounded-l-md border border-gray-300 dark:border-gray-700 dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-500 focus:ring-primary-500 focus:border-primary-500"
            />
            <button
              type="submit"
              class="bg-primary-600 text-white px-4 py-2 rounded-r-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
      <p class="text-center text-gray-500 dark:text-gray-400 text-sm">
        &copy; {currentYear} StockSage. All rights reserved.
      </p>
    </div>
  </div>
</footer>
