---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="md:flex md:justify-between">
      <!-- Site info and description -->
      <div class="mb-8 md:mb-0 md:w-1/3">
        <a href="/" class="flex items-center mb-4">
          <span class="text-2xl font-bold text-primary-600 dark:text-primary-400">StockSage</span>
        </a>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
          Insightful analysis and practical lessons on Indian and global stock markets.
        </p>
        <div class="flex space-x-4">
          <!-- Social media icons -->
          <a href="#" class="text-gray-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
            <span class="sr-only">Twitter</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
            </svg>
          </a>
          <a href="#" class="text-gray-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
            <span class="sr-only">LinkedIn</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="#" class="text-gray-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
            <span class="sr-only">GitHub</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.03-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.82c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.201 2.397.098 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.338 4.695-4.566 4.942.359.309.678.92.678 1.853 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.001 10.001 0 0022 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation Links & Subscribe -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-10 md:w-2/3">
        <div>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-5">Categories</h3>
          <ul class="space-y-3">
            <li>
              <a href="/categories/technical-analysis" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
                Technical Analysis
              </a>
            </li>
            <li>
              <a href="/categories/fundamental-analysis" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
                Fundamental Analysis
              </a>
            </li>
            <li>
              <a href="/categories/market-news" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
                Market News
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-5">Resources</h3>
          <ul class="space-y-3">
            <li>
              <a href="/about" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
                About Us
              </a>
            </li>
            <li>
              <a href="/contact" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
                Contact
              </a>
            </li>
            <li>
              <a href="/sitemap.xml" class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200 ease-in-out">
                Sitemap
              </a>
            </li>
          </ul>
        </div>

        <div class="md:col-span-1">
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider mb-5">Subscribe</h3>
          <p class="text-gray-600 dark:text-gray-400 mb-4">Get the latest updates directly to your inbox.</p>
          <form class="flex w-full mt-1">
            <label for="footer-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="footer-email"
              name="email-address"
              required
              placeholder="Enter your email"
              class="w-full flex-1 min-w-0 appearance-none rounded-l-md border border-gray-300 bg-white px-3 py-2 text-base text-gray-900 placeholder-gray-500 shadow-sm focus:z-10 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-50 dark:placeholder-gray-400 dark:focus:border-primary-500 dark:focus:ring-primary-500"
            />
            <button
              type="submit"
              class="-ml-px relative inline-flex items-center justify-center space-x-2 rounded-r-md border border-gray-300 bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700 focus:outline-none focus:ring-1 focus:ring-primary-500 focus:border-primary-500 dark:border-gray-600 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-500"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
      <p class="text-center text-gray-500 dark:text-gray-400 text-sm">
        &copy; {currentYear} StockSage. All rights reserved. Built with <a href="https://astro.build/" class="hover:underline">Astro</a>.
      </p>
    </div>
  </div>
</footer>
