---
/**
 * ResponsiveImage component
 * Optimizes images for different screen sizes and improves loading performance
 */

interface Props {
  src: string;
  alt: string;
  class?: string;
  sizes?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'sync' | 'async' | 'auto';
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  class: className = '',
  sizes = '(min-width: 1280px) 1280px, 100vw',
  loading = 'lazy',
  decoding = 'async',
  width,
  height
} = Astro.props;

// Determine image type and handle external images
const isExternal = src.startsWith('http');
const fileExtension = src.split('.').pop()?.toLowerCase();
const imageType = ['jpg', 'jpeg', 'png', 'webp', 'avif', 'gif'].includes(fileExtension || '') 
  ? fileExtension 
  : 'jpeg';

// NOTE: We're disabling responsive image sizes since we don't have a build pipeline generating them
// In a production environment, you would want to generate these image sizes
// or use Astro's built-in image optimization

// Disabling srcset generation - using original images only to prevent 404 errors
const srcset = undefined; // Don't use any srcset until image processing is set up
---

{isExternal ? (
  <img 
    src={src} 
    alt={alt}
    class={className}
    loading={loading}
    decoding={decoding}
    width={width}
    height={height}
  />
) : (
  <picture>
    {/* We're only using the original format since WebP versions aren't automatically generated */}
    {/* If you want to use WebP in the future, you'll need to add image processing to your build pipeline */}
    
    {/* Original format */}
    <img 
      src={src} 
      srcset={srcset}
      sizes={sizes} 
      alt={alt}
      class={className}
      loading={loading}
      decoding={decoding}
      width={width}
      height={height}
    />
  </picture>
)}
